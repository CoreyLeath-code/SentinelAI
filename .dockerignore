# Version control
.git
.gitignore

# Environment files (never bake secrets into images)
.env
.env.*
!.env.example

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
*.egg-info/
dist/
build/
venv/
.venv/

# Node / frontend
node_modules/
.next/
frontend/node_modules/
frontend/.next/

# C++ build artifacts (rebuilt inside the container)
drift_engine
drift-engine/drift_engine

# Go binaries (rebuilt inside the container)
ingestion-service/sentinel-ingestion
ingestion-service/ingestion-service

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# CI / GitHub
.github/

# Documentation and project management
*.md
LICENSE
DailyLog.md
Contributing.md
system_design.md
FILE Structure
Metrics.md

# Terraform state (contains sensitive data)
terraform/
*.tfstate
*.tfstate.*
*.tfvars

# Helm / k8s (not needed inside service containers)
helm/
k8s/

# Load tests
load_test/

# Monitoring config (mounted as volumes in compose)
monitoring/
